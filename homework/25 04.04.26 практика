<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>SASS Homework - All in One</title>
    <!-- Підключаємо стилі (умовно скомпільований SCSS) -->
    <style>

        :root {
            --primary: #2c3e50;
            --success: #27ae60;
            --danger: #e74c3c;
            --info: #3498db;
            --spacer: 15px;
        }

        
        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

     
        .container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            padding: 30px;
        }

      
        .glass-effect {
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            width: 100%;
            margin-top: 10px;
        }

        .btn-buy { background-color: #27ae60; } 
        .btn-cancel { background-color: #e74c3c; } 
        .btn-info { background-color: #3498db; } 

        .btn:hover { opacity: 0.8; }

        .product-card {
            width: 250px;
            padding: 20px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 10px 15px rgba(0,0,0,0.1);
            transition: 0.3s;
            background: white;
        }

        /* Використання амперсанда & для hover */
        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 25px rgba(0,0,0,0.2);
        }

        .product-card img {
            width: 100%;
            border-radius: 10px;
            margin-bottom: 15px;
        }

        .product-card h2 {
            font-size: 1.2rem;
            color: #2c3e50;
            margin: 10px 0;
        }

        .product-card .price {
            font-weight: bold;
            color: #e74c3c;
            display: block;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- Картка товару з використанням Glassmorphism та Nesting -->
        <div class="product-card glass-effect">
            <img src="https://via.placeholder.com/200" alt="Product">
            <h2>Anime Figure</h2>
            <span class="price">1500 грн</span>
            
            <!-- Кнопки створені через @extend -->
            <button class="btn btn-buy">Buy Now</button>
            <button class="btn btn-info">Details</button>
            <button class="btn btn-cancel">Cancel</button>
        </div>
    </div>

</body>
</html>