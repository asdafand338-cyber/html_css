<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Завдання 1 - Фрукти</title>
    <style>
        body { background-color: #f0f0f0; padding: 50px; }
        .list-container {
            background-color: #e68a9e; 
            padding: 20px;
            width: 400px;
        }
        ol { list-style-type: none; counter-reset: my-counter; padding: 0; }
        li {
            background-color: #c95c73; 
            margin-bottom: 10px;
            padding: 10px;
            color: white;
            display: flex;
            align-items: center;
        }
        li::before {
            counter-increment: my-counter;
            content: counter(my-counter) ". ";
            margin-right: 15px;
        }
        .text-bg {
            background-color: #8a3344; 
            padding: 5px 15px;
            display: inline-block;
        }
    </style>
</head>
<body>
    <div class="list-container">
        <ol>
            <li><span class="text-bg">Apple</span></li>
            <li><span class="text-bg">Orange</span></li>
            <li><span class="text-bg">Pineapple</span></li>
            <li><span class="text-bg">Pear</span></li>
            <li><span class="text-bg">Cherry</span></li>
        </ol>
    </div>
</body>
</html>
