<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Завдання 3 - Спливаючі іконки</title>
    <style>
        body { background-color: #fff9c4; font-family: sans-serif; text-align: center; }
        
        .gallery {
            display: flex;
            justify-content: center;
            align-items: flex-end;
            height: 300px;
            gap: 20px;
            padding-bottom: 50px;
        }

        .icon {
            width: 80px;
            opacity: 0;
            position: relative;
            bottom: -200px; 
            animation: slideUp 2s ease forwards;
        }

        .icon:nth-child(1) { animation-delay: 0s; }
        .icon:nth-child(2) { animation-delay: 0.5s; }
        .icon:nth-child(3) { animation-delay: 1s; }
        .icon:nth-child(4) { animation-delay: 1.5s; }
        .icon:nth-child(5) { animation-delay: 2s; }

        @keyframes slideUp {
            to {
                bottom: 0;
                opacity: 1;
            }
        }
    </style>
</head>
<body>
    <h1>HELLO, MY SITE!</h1>
    
    <div class="gallery">
        <img src="calc.png" class="icon" alt="1">
        <img src="book.png" class="icon" alt="2">
        <img src="list.png" class="icon" alt="3">
        <img src="palette.png" class="icon" alt="4">
        <img src="pencil.png" class="icon" alt="5">
    </div>
</body>
</html>