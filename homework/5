<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Завдання 1 - Прогрес-бар</title>
    <style>
        .progress-container {
            width: 300px;
            height: 50px;
            border: 4px solid orange;
            position: relative;
            margin: 50px auto;
            overflow: hidden;
        }
        .bar {
            width: 80px;
            height: 100%;
            background-color: orange;
            position: absolute;
            animation: moveBar 3s linear infinite;
        }
        @keyframes moveBar {
            0% { left: -80px; }
            100% { left: 300px; }
        }
    </style>
</head>
<body>
    <div class="progress-container">
        <div class="bar"></div>
    </div>
</body>
</html>
