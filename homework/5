<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Завдання 2 - Жива іконка</title>
    <style>
        .icon-box {
            text-align: center;
            margin-top: 100px;
            padding: 50px;
            background-color: #f0f0f0;
        }
        .heart-icon {
            width: 150px;
            filter: grayscale(100%);
            transition: all 5s ease; 
            cursor: pointer;
        }
        .heart-icon:hover {
            filter: grayscale(0%);
            transform: scale(1.5); 
        }
    </style>
</head>
<body>
    <div class="icon-box">
        <img src="heart.png" alt="Heart" class="heart-icon">
    </div>
</body>
</html>
