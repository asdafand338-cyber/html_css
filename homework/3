<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Cats Gallery</title>
    <style>
        .gallery-container {
            width: 500px;
            border: 1px solid #ddd;
            margin: 20px auto;
            text-align: center;
            font-family: sans-serif;
        }
        .header { background-color: #f4f4f4; padding: 10px; font-weight: bold; border-bottom: 1px solid #ddd; }
        iframe {
            width: 100%;
            height: 300px;
            border: none;
            padding: 20px 0;
        }
        .thumbnails {
            display: flex;
            justify-content: space-around;
            padding: 10px;
            border-top: 1px solid #ddd;
            background-color: #f9f9f9;
        }
        .thumbnails img {
            width: 60px;
            height: 60px;
            border: 1px solid #ccc;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="gallery-container">
        <div class="header">CATS GALLERY</div>
        
        <iframe src="cat1.png" name="display-frame"></iframe>

        <div class="thumbnails">
            <a href="cat1.png" target="display-frame"><img src="cat1.png" alt="Cat 1"></a>
            <a href="cat2.png" target="display-frame"><img src="cat2.png" alt="Cat 2"></a>
            <a href="cat3.png" target="display-frame"><img src="cat3.png" alt="Cat 3"></a>
            <a href="cat4.png" target="display-frame"><img src="cat4.png" alt="Cat 4"></a>
            <a href="cat5.png" target="display-frame"><img src="cat5.png" alt="Cat 5"></a>
            <a href="cat6.png" target="display-frame"><img src="cat6.png" alt="Cat 6"></a>
        </div>
    </div>

</body>
</html>