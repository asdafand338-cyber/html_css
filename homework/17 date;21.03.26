<style>
    .btn-animate {
        padding: 15px 30px;
        font-size: 18px;
        background-color: #6200ee;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        transition: all 0.3s ease; 
    }

    .btn-animate:hover {
        background-color: #3700b3;
        box-shadow: 0 10px 20px rgba(0,0,0,0.3); 
        transform: translateY(-3px); 

    .btn-animate:active {
        transform: translateY(1px); 
    }
</style>
<button class="btn-animate">HOVER ME</button>
