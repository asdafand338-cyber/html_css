<style>
    .card-container {
        position: relative;
        width: 300px;
        height: 200px;
        overflow: hidden;
    }

    .card-overlay {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background-color: rgba(0,0,0,0.7);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0; 
        transition: opacity 0.5s ease;
    }

    .card-container:hover .card-overlay {
        opacity: 1; 
</style>

<div class="card-container">
    <img src="your-image.jpg" alt="Work" style="width:100%">
    <div class="card-overlay">
        <h3>Project Title</h3>
    </div>
</div>
