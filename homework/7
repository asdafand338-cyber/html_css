<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>English Tenses Table</title>
    <style>
        table {
            width: 100%;
            border-collapse: collapse;
            font-family: Arial, sans-serif;
            text-align: center;
        }
        th, td {
            border: 1px solid #777;
            padding: 8px;
        }
    
        .col-yellow { background-color: #fff9c4; font-weight: bold; }
        .col-blue { background-color: #e3f2fd; }
        .col-red { background-color: #ffebee; }
        .col-green { background-color: #e8f5e9; }
        .col-purple { background-color: #f3e5f5; }

        .meaning-text { font-style: italic; font-size: 0.9em; color: #555; }
        .period-text { background-color: #f5f5f5; font-style: italic; font-size: 0.85em; }
        .formula { font-weight: bold; }
    </style>
</head>
<body>

    <table>
        <thead>
            <tr>
                <th class="col-yellow">ASPECT</th>
                <th class="col-blue">SIMPLE</th>
                <th class="col-red">PROGRESSIVE</th>
                <th class="col-green">PERFECT</th>
                <th class="col-purple">PERFECT PROGRESSIVE</th>
            </tr>
            <tr class="meaning-text">
                <th class="col-yellow">MEANING</th>
                <th class="col-blue">a common aspect<br><b>When?</b></th>
                <th class="col-red">a process<br><b>At what time?</b></th>
                <th class="col-green">priority<br><b>By what time?</b></th>
                <th class="col-purple">priority + process<br><b>Since what time? How long?</b></th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td class="period-text" colspan="1">Period of time</td>
                <td class="period-text">usually, often, always, etc.</td>
                <td class="period-text">now, at the moment</td>
                <td class="period-text">ever, never, just, already</td>
                <td class="period-text">since 3 p.m., for a long time</td>
            </tr>
            <tr>
                <td rowspan="3" class="col-yellow">Present</td>
                <td class="col-blue">+</td>
                <td class="col-blue formula">V / Vs</td>
                <td class="col-red formula">am/is/are + Ving</td>
                <td class="col-green formula">have/has + Ved/V3</td>
                <td class="col-purple formula">have/has + been + Ving</td>
            </tr>
            <tr>
                <td class="col-blue">?</td>
                <td class="col-blue">do/does + V</td>
                <td class="col-red">inversion