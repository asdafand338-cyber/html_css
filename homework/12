<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Vertical Dropdown Menu</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f4f4; padding: 50px; }
        
        .menu {
            list-style: none;
            padding: 0;
            margin: 0;
            width: 200px;
            background-color: #fff;
            border: 1px solid #ddd;
        }

        .menu > li {
            position: relative; /* Щоб підменю позиціонувалося відносно пункту */
            border-bottom: 1px solid #eee;
        }

        .menu li a {
            display: block;
            padding: 12px 15px;
            text-decoration: none;
            color: #333;
            background-color: #fff;
        }

        /* Ефект при наведенні на пункт */
        .menu li:hover > a {
            background-color: #007bff;
            color: white;
        }

        /* Приховуємо підменю за замовчуванням */
        .submenu {
            display: none;
            position: absolute;
            left: 100%; /* Зсуваємо вправо від основного меню */
            top: 0;
            list-style: none;
            padding: 0;
            width: 180px;
            background-color: #fff;
            border: 1px solid #ddd;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
        }

        /* Показуємо підменю при наведенні на батьківський li */
        .menu li:hover .submenu {
            display: block;
        }
    </style>
</head>
<body>

    <ul class="menu">
        <li><a href="#">Електроніка</a>
            <ul class="submenu">
                <li><a href="#">Смартфони</a></li>
                <li><a href="#">Ноутбуки</a></li>
                <li><a href="#">Планшети</a></li>
            </ul>
        </li>
        <li><a href="#">Одяг</a>
            <ul class="submenu">
                <li><a href="#">Чоловічий</a></li>
                <li><a href="#">Жіночий</a></li>
                <li><a href="#">Дитячий</a></li>
            </ul>
        </li>
        <li><a href="#">Дім та сад</a></li>
        <li><a href="#">Спорт</a></li>
    </ul>

</body>
</html>
