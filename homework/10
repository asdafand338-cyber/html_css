<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Блочна верстка - Layout</title>
    <style>
        
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f5f5f5;
            display: flex;
            flex-direction: column;
            gap: 10px; 
            min-height: 90vh;
        }

        
        .box {
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 20px;
            border-radius: 4px;
        }

        header {
            height: 100px;
            background-color: #4a90e2; 
        }

        
        .container {
            display: flex;
            gap: 10px;
            flex-grow: 1; 
        }

        main {
            flex: 3; 
            height: 400px;
            background-color: #50c878; 
        }

        aside {
            flex: 1; 
            background-color: #f5a623; 
        }

        footer {
            height: 80px;
            background-color: #9b59b6;
        }

    
        @media (max-width: 600px) {
            .container {
                flex-direction: column;
            }
            aside {
                height: 100px;
            }
        }
    </style>
</head>
<body>

    <header class="box">HEADER</header>

    <div class="container">
        <main class="box">MAIN CONTENT</main>
        <aside class="box">SIDEBAR</aside>
    </div>

    <footer class="box">FOOTER</footer>

</body>
</html>