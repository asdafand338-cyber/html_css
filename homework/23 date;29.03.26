<!DOCTYPE html>
<html>
<head>
    <title>Моя робота 123</title>
    <style>
        
        body { font-family: sans-serif; background-color: #f0f0f0; }
        
        
        .kartka-fon { background-color: #84c3b6; width: 400px; padding: 20px; border-radius: 10px; margin: 20px auto; color: white; }
        .orange-banner { background: #d35400; padding: 5px; width: 200px; margin-bottom: 20px; }
        .pole { width: 90%; margin-bottom: 10px; background: rgba(255,255,255,0.3); border: none; padding: 5px; }

    
        .uikit { background: white; padding: 20px; border: 1px solid black; max-width: 600px; margin: auto; }
        .inp-v { border: 1px solid green; }
        .inp-inv { border: 1px solid red; }
        .knopka-ok { background: #2ecc71; color: white; border: none; padding: 10px; }
        .knopka-bad { background: #e74c3c; color: white; border: none; padding: 10px; }
        .krug { border-radius: 50px; width: 30px; height: 30px; }

       
        .reg-forma { background: white; border: 1px solid #ccc; width: 800px; margin: 20px auto; padding: 20px; }
        .col-left { width: 45%; float: left; }
        .col-right { width: 45%; float: right; }
        .clear { clear: both; } /* старий метод вирівнювання */
        .knopka-send { background: teal; color: white; padding: 10px 20px; border: none; margin-top: 20px; }
    </style>
</head>
<body>

<h2 align="center"></h2>
<div class="kartka-fon">
    <div class="orange-banner">CREDIT CARD DETAILS</div>
    Card Number<br>
    <input type="text" class="pole" placeholder="1234 5678 9012 3456"><br>
    Name On Card<br>
    <input type="text" class="pole" placeholder="NAME SURNAME"><br>
    <div style="display: flex;">
        <div style="width: 50%;">Expire Date<br><input type="text" class="pole" style="width: 60px;"></div>
        <div style="width: 50%;">CSV No.<br><input type="text" class="pole" style="width: 60px;"></div>
    </div>
</div>

<hr>

<h2 align="center"></h2>
<div class="uikit">
    <b>Inputs:</b><br>
    <input type="text"> 
    <input type="text" class="inp-v" value="valid text"> 
    <input type="text" class="inp-inv" value="invalid text"><br><br>
    
    <b>Checkboxes:</b><br>
    <input type="checkbox" checked> Subscribe 
    <input type="checkbox"> Subscribe<br><br>

    <b>Buttons:</b><br>
    <button class="knopka-ok">Active</button>
    <button class="knopka-ok" style="opacity: 0.8;">Hover</button>
    <button class="knopka-bad">Danger</button>
    <button class="knopka-bad" style="border: 2px solid black;">Hover</button>
    <button disabled>Disabled</button>
    <button class="knopka-ok krug">+</button>
    <button class="knopka-bad krug">-</button>
</div>

<hr>

<h2 align="center"></h2>
<div class="reg-forma">
    <div class="col-left">
        <h3>Registration form</h3>
        Логін: <input type="text" style="border: none; border-bottom: 1px solid black; width: 100%;"><br><br>
        Email: <input type="text" style="border: none; border-bottom: 1px solid black; width: 100%;"><br><br>
        Пароль: <input type="text" style="border: none; border-bottom: 1px solid black; width: 100%;"><br><br>
        <input type="checkbox"> I want news<br>
        <input type="checkbox"> I agree
    </div>
    <div class="col-right">
        <h3>Personal details</h3>
        Ім'я: <input type="text" style="border: none; border-bottom: 1px solid black; width: 100%;"><br><br>
        Прізвище: <input type="text" style="border: none; border-bottom: 1px solid black; width: 100%;"><br><br>
        Стать: <select><option>Male</option><option>Female</option></select>
    </div>
    <div class="clear"></div>
    <center><button class="knopka-send">SUBMIT</button></center>
</div>

</body>
</html>