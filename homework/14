<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Our Team - Adaptive Grid</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            padding: 40px;
        }

        .section-title {
            text-align: center;
            margin-bottom: 40px;
            color: #333;
        }

     
        .team-grid {
            display: grid;
        
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

   
        .team-card {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            text-align: center;
            transition: transform 0.3s ease;
        }

        .team-card:hover {
            transform: translateY(-10px);
        }

        .photo-placeholder {
            width: 100%;
            height: 250px;
            background-color: #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #777;
            font-size: 50px;
        }

        .team-info {
            padding: 20px;
        }

        .team-name {
            margin: 0;
            font-size: 20px;
            color: #2c3e50;
        }

        .team-role {
            color: #3498db;
            font-size: 14px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 10px 0;
        }

        .social-links {
            margin-top: 15px;
            display: flex;
            justify-content: center;
            gap: 10px;
        }

        .social-icon {
            width: 30px;
            height: 30px;
            background: #eee;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.3s;
        }

        .social-icon:hover {
            background: #3498db;
            color: white;
        }
    </style>
</head>
<body>

    <h1 class="section-title">OUR TEAM</h1>

    <div class="team-grid">
        <div class="team-card">
            <div class="photo-placeholder">👤</div>
            <div class="team-info">
                <h3 class="team-name">John Doe</h3>
                <p class="team-role">CEO & Founder</p>
                <div class="social-links">
                    <span class="social-icon">f</span>
                    <span class="social-icon">t</span>
                    <span class="social-icon">in</span>
                </div>
            </div>
        </div>

        <div class="team-card">
            <div class="photo-placeholder">👤</div>
            <div class="team-info">