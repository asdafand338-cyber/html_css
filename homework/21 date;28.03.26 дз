body {
    background-color: #f0f0f0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    padding-top: 50px;
}

.main-box {
    width: 500px;
    height: 300px;
    background-color: #93c1c1; 
    margin: 0 auto;
    position: relative;
    border-radius: 8px;
    padding: 20px;
    /* добавил небольшую тень для объема */
    box-shadow: 5px 5px 15px rgba(0,0,0,0.1);
}

.orange-top {
    background-color: #d36324;
    color: white;
    padding: 10px 25px;
    font-weight: bold;
    position: absolute;
    top: 30px;
    left: -15px; 
    width: 350px;
}

.card-form {
    margin-top: 80px;
}

.card-form p {
    margin: 5px 0;
    font-size: 13px;
    color: #555;
}

.input-row input {
    width: 90%;
    padding: 8px;
    margin-bottom: 15px;
    border: none;
    background-color: rgba(255,255,255,0.2); 
}

.bottom-inputs {
    display: flex;
    justify-content: flex-start;
    gap: 30px;
}

.small-in {
    width: 60px;
    padding: 8px;
    border: none;
    background-color: rgba(255,255,255,0.2);
}

.csv input {
    width: 80px;
    padding: 8px;
    border: none;
    background-color: rgba(255,255,255,0.2);
}


input {
    border-radius: 2px;
}