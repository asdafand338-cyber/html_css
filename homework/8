<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Multilevel Menu</title>
    <style>
        nav { background-color: #5d9b71; }
        ul { list-style: none; margin: 0; padding: 0; display: flex; }
        
        li { position: relative; } 
        
        li a {
            display: block;
            padding: 15px 25px;
            color: white;
            text-decoration: none;
            border-right: 1px solid #4a7d5b;
        }

        li:hover > a { background-color: #4a7d5b; } 

      
        ul ul {
            display: none;
            position: absolute;
            top: 100%; left: 0;
            flex-direction: column;
            background-color: #5d9b71;
            min-width: 150px;
        }

    
        ul ul ul { top: 0; left: 100%; }

        
        li:hover > ul { display: flex; }
    </style>
</head>
<body>
    <nav>
        <ul>
            <li><a href="#">Home</a></li>
            <li>
                <a href="#">Categories</a>
                <ul>
                    <li><a href="#">Man</a></li>
                    <li>
                        <a href="#">Women</a>
                        <ul>
                            <li><a href="#">Dress</a></li>
                            <li><a href="#">Pants</a></li>
                            <li><a href="#">Shoes</a></li>
                        </ul>
                    </li>
                    <li><a href="#">Kids</a></li>
                </ul>
            </li>
            <li><a href="#">About</a></li>
            <li><a href="#">Contacts</a></li>
        </ul>
    </nav>
    <div style="padding: 20px;">
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nulla ac augue quis ante blandit blandit eu et massa...</p>
    </div>
</body>
</html>