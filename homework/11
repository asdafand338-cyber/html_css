<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Feedback Form</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #eee; padding: 40px; }
        fieldset { background-color: white; border: 1px solid #999; padding: 20px; width: 450px; margin: auto; }
        legend { font-weight: bold; padding: 0 10px; }
        .row { margin-bottom: 15px; display: flex; }
        .row label { width: 100px; }
        input[type="text"], textarea { flex: 1; padding: 5px; }
        textarea { height: 100px; resize: vertical; }
        .btn-row { text-align: right; }
    </style>
</head>
<body>
    <form>
        <fieldset>
            <legend>Step 1: Your details</legend>
            <div class="row">
                <label>Name</label>
                <input type="text" placeholder="First and last name">
            </div>
            <div class="row">
                <label>Email</label>
                <input type="text" placeholder="example@domain.com">
            </div>
            <div class="row">
                <label>Phone</label>
                <input type="text" placeholder="e.g. +380...">
            </div>
        </fieldset>

        <br>

        <fieldset>
            <legend>Step 2: Your message</legend>
            <div class="row">
                <label>Message</label>
                <textarea placeholder="Write your message here..."></textarea>
            </div>
            <div class="btn-row">
                <button type="submit">Send Message</button>
            </div>
        </fieldset>
    </form>
</body>
</html>