<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Registration Form</title>
    <style>
        body { font-family: Arial, sans-serif; display: flex; justify-content: center; padding: 20px; }
        .form-container { border: 1px solid #ccc; padding: 20px; width: 400px; background-color: #f9f9f9; }
        .form-group { display: flex; justify-content: space-between; margin-bottom: 15px; align-items: center; }
        label { font-weight: bold; font-size: 14px; }
        input[type="text"], input[type="password"], select { width: 220px; padding: 5px; border: 1px solid #999; }
        .buttons { text-align: center; margin-top: 20px; }
        button { padding: 5px 20px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="form-container">
        <form>
            <div class="form-group">
                <label>Login:</label>
                <input type="text" name="login">
            </div>
            <div class="form-group">
                <label>Password:</label>
                <input type="password" name="password">
            </div>
            <div class="form-group">
                <label>City:</label>
                <select name="city">
                    <option value="kyiv">Kyiv</option>
                    <option value="lviv">Lviv</option>
                    <option value="odesa">Odesa</option>
                </select>
            </div>
            <div class="form-group">
                <label>Gender:</label>
                <div style="width: 220px;">
                    <input type="radio" name="gender" value="male"> Male
                    <input type="radio" name="gender" value="female"> Female
                </div>
            </div>
            <div class="form-group">
                <label>Interests:</label>
                <div style="width: 220px;">
                    <input type="checkbox" name="int1"> Football
                    <input type="checkbox" name="int2"> Chess
                    <input type="checkbox" name="int3"> Music
                </div>
            </div>
            <div class="buttons">
                <button type="reset">Reset</button>
                <button type="submit">Submit</button>
            </div>
        </form>
    </div>
</body>
</html>
