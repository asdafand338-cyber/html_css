<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Semantic Layout</title>
    <style>
        body { display: flex; flex-direction: column; gap: 10px; font-family: sans-serif; text-align: center; color: white; }
        header, nav, main, aside, footer { padding: 20px; border-radius: 5px; }
        
        header { background-color: #4a90e2; }
        nav { background-color: #f5a623; }
        .content-wrapper { display: flex; gap: 10px; }
        main { background-color: #50c878; flex: 3; height: 200px; }
        aside { background-color: #e74c3c; flex: 1; }
        footer { background-color: #9b59b6; }
    </style>
</head>
<body>
    <header>HEADER</header>
    <nav>NAV</nav>
    <div class="content-wrapper">
        <main>MAIN</main>
        <aside>ASIDE</aside>
    </div>
    <footer>FOOTER</footer>
</body>
</html>
